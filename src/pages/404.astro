---
import MainGridLayout from "../layouts/MainGridLayout.astro";
---

<MainGridLayout title="Page Not Found">
    <div class="card-base flex flex-col items-center justify-center py-24 px-6">
        <div class="text-8xl font-bold text-[var(--primary)] mb-4">404</div>
        <h1 class="text-2xl font-bold text-90 mb-2">Page Not Found</h1>
        <p class="text-50 mb-8 text-center">The page you're looking for doesn't exist or has been moved.</p>
        <a href="/" class="btn-regular rounded-lg px-6 py-3 font-bold">Go Home</a>
    </div>
</MainGridLayout>
