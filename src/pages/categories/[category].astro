---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import MainGridLayout from "../../layouts/MainGridLayout.astro";
import { getPostUrlBySlug } from "../../utils/url-utils";

export async function getStaticPaths() {
	const allPosts = await getCollection("posts", ({ data }) => {
		return import.meta.env.PROD ? data.draft !== true : true;
	});
	const categorySet = new Set<string>();
	for (const post of allPosts) {
		if (post.data.category) {
			categorySet.add(post.data.category);
		}
	}
	return Array.from(categorySet).map((category) => {
		const posts = allPosts
			.filter((p) => p.data.category === category)
			.sort(
				(a, b) =>
					new Date(b.data.published).getTime() -
					new Date(a.data.published).getTime(),
			);
		return {
			params: { category },
			props: { posts, category },
		};
	});
}

const { posts, category } = Astro.props;
---

<MainGridLayout title={`Category: ${category}`}>
  <div class="card-base p-6 md:p-9">
    <h1 class="text-2xl font-bold text-90 mb-6 flex items-center gap-2">
      <Icon name="material-symbols:book-2-outline-rounded" class="text-[var(--primary)] text-2xl" />
      <span>{category}</span>
      <span class="text-sm text-50 font-normal">({posts.length} {posts.length === 1 ? "post" : "posts"})</span>
    </h1>
    {posts.length === 0 && <p class="text-50">No posts found in this category.</p>}
    <ul class="flex flex-col gap-3">
      {posts.map((entry) => (
        <li class="flex items-center gap-3">
          <Icon name="material-symbols:chevron-right-rounded" class="text-[var(--primary)] text-xl shrink-0" />
          <a href={getPostUrlBySlug(entry.slug)} class="link-underline text-lg font-medium text-90 hover:text-[var(--primary)] transition">
            {entry.data.title}
          </a>
          <span class="text-sm text-50 ml-auto shrink-0">{new Date(entry.data.published).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}</span>
        </li>
      ))}
    </ul>
  </div>
</MainGridLayout>
